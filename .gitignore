# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
# Commit bootstrap lock files for reproducible provider versions
!bootstrap/**/.terraform.lock.hcl
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive variable files (allow checked-in template tfvars under config/scenarios)
*.auto.tfvars
*.auto.tfvars.json

# Office temp / lock files
~$*

# PowerShell
*.psd1.bak
*.psm1.bak

# OS / editor
.DS_Store
Thumbs.db
.vs/
.vscode/*.log

# Local secrets (never commit)
.env
.env.*
secrets.*
*.pem
*.key

bootstrap/alz/github/*.log
bootstrap/alz/github/.terraform/
bootstrap/alz/github/*.tfstate*
bootstrap/alz/github/*.tfplan

# Apply / plan transcripts (root-level)
standalone-*.log
standalone-*.tfplan
# hub_and_spoke cloud-test fixture artefacts
hub01-apply*.log
bootstrap/alz/hub/*.log
bootstrap/alz/hub/terraform.tfvars.json

# Ad-hoc tfvars dropped at repo root during local debugging
/good.tfvars
/standalone-remote.tfvars
/*.tfvars

# Local terraform state at repo root (only sandbox/template state is allowed)
/terraform.tfstate
/terraform.tfstate.backup

# L3/L4 cloud-test transcripts (root-level)
l3-*.log
l4-*.log
