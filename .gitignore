# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
# Commit bootstrap lock files for reproducible provider versions
!bootstrap/**/.terraform.lock.hcl
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive variable files (allow checked-in template tfvars under config/scenarios)
*.auto.tfvars
*.auto.tfvars.json

# Office temp / lock files
~$*

# PowerShell
*.psd1.bak
*.psm1.bak

# OS / editor
.DS_Store
Thumbs.db
.vs/
.vscode/*.log

# Local secrets (never commit)
.env
.env.*
secrets.*
*.pem
*.key

bootstrap/alz/github/*.log
bootstrap/alz/github/.terraform/
bootstrap/alz/github/*.tfstate*
bootstrap/alz/github/*.tfplan

# Apply / plan transcripts (root-level)
standalone-*.log
standalone-*.tfplan
